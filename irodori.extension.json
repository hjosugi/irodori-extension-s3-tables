{
  "$schema": "https://irodori.dev/schemas/irodori.extension.schema.json",
  "manifestVersion": 1,
  "id": "irodori.s3-tables",
  "name": "S3 Tables Connector",
  "version": "0.1.0",
  "publisher": "irodori",
  "description": "S3 Tables Connector contributes the S3 Tables database connector through the native connector ABI.",
  "license": "MIT OR 0BSD",
  "repository": "https://github.com/hjosugi/irodori-extension-s3-tables",
  "apiVersion": "0.1",
  "runtime": "native",
  "entry": "dist/native",
  "permissions": [
    "connections:read",
    "connections:write",
    "queries:run",
    "metadata:read",
    "native",
    "connectors"
  ],
  "contributes": {
    "connectors": [
      {
        "id": "s3Tables.connector",
        "engine": "s3Tables",
        "label": "S3 Tables",
        "aliases": [
          "s3Tables",
          "s3-tables",
          "AWS S3 Tables",
          "S3",
          "Tables"
        ],
        "defaultPort": 443,
        "wire": "lakehouse",
        "module": "s3Tables.driver",
        "features": [
          "metadata",
          "sql"
        ],
        "connection": {
          "schemaVersion": 1,
          "inferEnvironmentFrom": [
            "name",
            "id",
            "host",
            "database",
            "url"
          ],
          "compatibility": {
            "addsRequiredProfileFields": false,
            "acceptsExistingProfiles": true
          },
          "defaults": {
            "engine": "s3Tables",
            "wire": "lakehouse",
            "port": 443,
            "readOnly": false
          },
          "endpoint": {
            "modes": [
              "cloudResource",
              "customEndpoint",
              "connectionString"
            ],
            "defaultPort": 443,
            "fields": [
              {
                "id": "region",
                "label": "AWS region",
                "type": "string",
                "option": "region",
                "required": true
              },
              {
                "id": "catalogType",
                "label": "Catalog type",
                "type": "string",
                "option": "catalogType",
                "default": "s3TablesIcebergRest",
                "required": true
              },
              {
                "id": "tableBucketArn",
                "label": "Table bucket ARN",
                "type": "string",
                "option": "tableBucketArn",
                "required": true
              },
              {
                "id": "namespace",
                "label": "Namespace",
                "type": "string",
                "option": "namespace"
              },
              {
                "id": "tableName",
                "label": "Table",
                "type": "string",
                "option": "tableName"
              },
              {
                "id": "accessModel",
                "label": "Access model",
                "type": "string",
                "option": "accessModel",
                "default": "iam"
              },
              {
                "id": "credentialVending",
                "label": "Credential vending",
                "type": "boolean",
                "option": "credentialVending",
                "default": true
              },
              {
                "id": "endpoint",
                "label": "Custom endpoint",
                "type": "uri",
                "profileField": "host"
              }
            ]
          },
          "profileFields": [
            {
              "id": "id",
              "label": "Connection ID",
              "type": "string",
              "profileField": "id",
              "required": true
            },
            {
              "id": "url",
              "label": "Connection URL or DSN",
              "type": "uri",
              "profileField": "url"
            },
            {
              "id": "user",
              "label": "User",
              "type": "string",
              "profileField": "user"
            },
            {
              "id": "region",
              "label": "AWS region",
              "type": "string",
              "option": "region",
              "required": true
            },
            {
              "id": "catalogType",
              "label": "Catalog type",
              "type": "string",
              "option": "catalogType",
              "default": "s3TablesIcebergRest",
              "required": true
            },
            {
              "id": "tableBucketArn",
              "label": "Table bucket ARN",
              "type": "string",
              "option": "tableBucketArn",
              "required": true
            },
            {
              "id": "namespace",
              "label": "Namespace",
              "type": "string",
              "option": "namespace"
            },
            {
              "id": "tableName",
              "label": "Table",
              "type": "string",
              "option": "tableName"
            },
            {
              "id": "accessModel",
              "label": "Access model",
              "type": "string",
              "option": "accessModel",
              "default": "iam"
            },
            {
              "id": "credentialVending",
              "label": "Credential vending",
              "type": "boolean",
              "option": "credentialVending",
              "default": true
            },
            {
              "id": "endpoint",
              "label": "Custom endpoint",
              "type": "uri",
              "profileField": "host"
            },
            {
              "id": "readOnly",
              "label": "Read-only connection",
              "type": "boolean",
              "profileField": "readOnly",
              "default": false
            },
            {
              "id": "options",
              "label": "Driver options",
              "type": "map",
              "profileField": "options"
            }
          ],
          "authMethods": [
            {
              "id": "connectionString",
              "label": "Connection string / DSN",
              "kind": "connectionString",
              "secretPurposes": [],
              "fields": [
                {
                  "id": "url",
                  "label": "Connection URL or DSN",
                  "type": "uri",
                  "profileField": "url",
                  "required": true
                }
              ]
            },
            {
              "id": "awsSigV4",
              "label": "AWS SigV4",
              "kind": "iam",
              "secretPurposes": [
                "token"
              ],
              "fields": [
                {
                  "id": "accessKeyId",
                  "label": "Access key ID",
                  "type": "string"
                },
                {
                  "id": "secretAccessKey",
                  "label": "Secret access key",
                  "type": "secret",
                  "secretPurpose": "token"
                },
                {
                  "id": "sessionToken",
                  "label": "Session token",
                  "type": "secret",
                  "secretPurpose": "token"
                },
                {
                  "id": "region",
                  "label": "Region",
                  "type": "string",
                  "option": "region"
                }
              ]
            },
            {
              "id": "awsProfile",
              "label": "AWS shared config profile",
              "kind": "iam",
              "secretPurposes": [],
              "fields": [
                {
                  "id": "profile",
                  "label": "Profile",
                  "type": "string",
                  "option": "awsProfile"
                },
                {
                  "id": "region",
                  "label": "Region",
                  "type": "string",
                  "option": "region"
                }
              ]
            },
            {
              "id": "awsSso",
              "label": "AWS IAM Identity Center / SSO",
              "kind": "iam",
              "secretPurposes": [
                "token"
              ],
              "fields": [
                {
                  "id": "ssoSession",
                  "label": "SSO session",
                  "type": "string",
                  "option": "ssoSession"
                },
                {
                  "id": "region",
                  "label": "Region",
                  "type": "string",
                  "option": "region"
                }
              ]
            },
            {
              "id": "webIdentity",
              "label": "AWS web identity",
              "kind": "iam",
              "secretPurposes": [
                "token"
              ],
              "fields": [
                {
                  "id": "roleArn",
                  "label": "Role ARN",
                  "type": "string",
                  "option": "roleArn"
                },
                {
                  "id": "webIdentityToken",
                  "label": "Web identity token",
                  "type": "secret",
                  "secretPurpose": "token"
                }
              ]
            },
            {
              "id": "sessionToken",
              "label": "AWS session token",
              "kind": "token",
              "secretPurposes": [
                "token"
              ],
              "fields": [
                {
                  "id": "token",
                  "label": "Token",
                  "type": "secret",
                  "secretPurpose": "token"
                }
              ]
            },
            {
              "id": "customDriverOptions",
              "label": "Custom driver options",
              "kind": "custom",
              "secretPurposes": [
                "password",
                "token",
                "privateKey",
                "privateKeyPassphrase"
              ],
              "fields": [
                {
                  "id": "options",
                  "label": "Driver options",
                  "type": "map",
                  "profileField": "options"
                }
              ]
            }
          ],
          "secretPurposes": [
            "token",
            "password",
            "privateKey",
            "privateKeyPassphrase"
          ],
          "tls": {
            "supported": true,
            "requiredByDefault": true,
            "modes": [
              "disable",
              "prefer",
              "require",
              "verifyCa",
              "verifyFull",
              "clientCertificate"
            ],
            "fields": [
              {
                "id": "caCertificate",
                "label": "CA certificate",
                "type": "pem"
              },
              {
                "id": "clientCertificate",
                "label": "Client certificate",
                "type": "pem"
              },
              {
                "id": "clientPrivateKey",
                "label": "Client private key",
                "type": "pem",
                "secretPurpose": "privateKey"
              }
            ]
          },
          "transports": [
            "direct",
            "sshTunnel",
            "socks5Proxy",
            "httpConnectProxy",
            "proxyChain"
          ],
          "optionNamespaces": [
            "profile.options",
            "driver",
            "tls",
            "network",
            "lakehouse",
            "s3Tables",
            "aws",
            "catalog",
            "objectStorage"
          ],
          "customDriverOptions": true
        }
      }
    ]
  },
  "capabilities": {
    "nativeModules": [
      {
        "id": "s3Tables.driver",
        "path": "dist/native",
        "platforms": [
          "windowsX64",
          "windowsArm64",
          "macosX64",
          "macosArm64",
          "linuxX64",
          "linuxArm64"
        ]
      }
    ]
  },
  "dev": {
    "watch": [
      "src",
      "connector.config.json",
      "irodori.extension.json"
    ]
  }
}
