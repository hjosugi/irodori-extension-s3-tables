{
  "$schema": "https://irodori.dev/schemas/irodori.extension.schema.json",
  "manifestVersion": 1,
  "id": "irodori.s3-tables",
  "name": "S3 Tables Connector",
  "version": "0.1.0",
  "publisher": "irodori",
  "description": "S3 Tables Connector contributes the S3 Tables database connector through the native connector ABI.",
  "license": "MIT OR 0BSD",
  "repository": "https://github.com/hjosugi/irodori-extension-s3-tables",
  "apiVersion": "0.1",
  "runtime": "native",
  "entry": "dist/native",
  "permissions": [
    "connections:read",
    "connections:write",
    "queries:run",
    "metadata:read",
    "native",
    "connectors"
  ],
  "contributes": {
    "connectors": [
      {
        "id": "s3Tables.connector",
        "engine": "s3Tables",
        "label": "S3 Tables",
        "aliases": [
          "s3Tables",
          "s3-tables",
          "AWS S3 Tables",
          "S3",
          "Tables"
        ],
        "defaultPort": 443,
        "wire": "lakehouse",
        "module": "s3Tables.driver",
        "features": [
          "metadata",
          "sql"
        ]
      }
    ]
  },
  "capabilities": {
    "nativeModules": [
      {
        "id": "s3Tables.driver",
        "path": "dist/native",
        "platforms": [
          "windowsX64",
          "windowsArm64",
          "macosX64",
          "macosArm64",
          "linuxX64",
          "linuxArm64"
        ]
      }
    ]
  },
  "dev": {
    "watch": [
      "src",
      "connector.config.json",
      "irodori.extension.json"
    ]
  }
}
