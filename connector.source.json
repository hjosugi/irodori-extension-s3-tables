{
  "schemaVersion": 1,
  "extensionId": "irodori.s3-tables",
  "visibility": "public",
  "version": "0.1.0",
  "connector": {
    "id": "s3Tables.connector",
    "engine": "s3Tables",
    "label": "S3 Tables",
    "aliases": [
      "s3Tables",
      "s3-tables",
      "AWS S3 Tables",
      "S3",
      "Tables"
    ],
    "defaultPort": 443,
    "wire": "lakehouse",
    "module": "s3Tables.driver",
    "features": [
      "metadata",
      "sql"
    ]
  },
  "connection": {
    "endpoint": {
      "modes": [
        "cloudResource",
        "customEndpoint",
        "connectionString"
      ],
      "defaultPort": 443,
        "fields": [
          {
            "id": "region",
            "label": "AWS region",
            "type": "string",
            "option": "region",
            "required": true
          },
          {
            "id": "catalogType",
            "label": "Catalog type",
            "type": "string",
            "option": "catalogType",
            "default": "s3TablesIcebergRest",
            "required": true
          },
          {
            "id": "tableBucketArn",
            "label": "Table bucket ARN",
            "type": "string",
            "option": "tableBucketArn",
            "required": true
          },
          {
            "id": "namespace",
            "label": "Namespace",
            "type": "string",
            "option": "namespace"
          },
          {
            "id": "tableName",
            "label": "Table",
            "type": "string",
            "option": "tableName"
          },
          {
            "id": "accessModel",
            "label": "Access model",
            "type": "string",
            "option": "accessModel",
            "default": "iam"
          },
          {
            "id": "credentialVending",
            "label": "Credential vending",
            "type": "boolean",
            "option": "credentialVending",
            "default": true
          },
          {
            "id": "endpoint",
            "label": "Custom endpoint",
            "type": "uri",
            "profileField": "host"
        }
      ]
    },
    "authMethods": [
      "connectionString",
      "awsSigV4",
      "awsProfile",
      "awsSso",
      "webIdentity",
      "sessionToken",
      "customDriverOptions"
    ],
    "tls": "required",
    "transports": "default",
    "optionNamespaces": [
      "lakehouse",
      "s3Tables",
      "aws",
      "catalog",
      "objectStorage"
    ],
    "customDriverOptions": true
  },
  "runtime": {
    "driverLinked": false
  },
  "source": {
    "knowledgeEngineStatus": "recognized_no_connector",
    "adapter": null
  }
}
